# ALEXVERSE Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Database Configuration
# ============================================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=alexverse
DB_USER=alexverse
DB_PASSWORD=your-secure-password-here

# ============================================================================
# Security & Authentication
# ============================================================================
JWT_SECRET=your-super-secure-random-jwt-secret-key-here-change-this
ADMIN_USER_ID=your-discord-admin-user-id

# ============================================================================
# External Services
# ============================================================================
DISCORD_BOT_TOKEN=your-discord-bot-token-here
OPENAI_API_KEY=your-openai-api-key-here

# ============================================================================
# Service URLs (for development)
# ============================================================================
CORE_API_URL=http://core-api:8000
LIFE_ENGINE_URL=http://life-simulation-engine:8002
AI_ORCHESTRATOR_URL=http://ai-orchestrator:8001

# ============================================================================
# Simulation Configuration
# ============================================================================
TICK_INTERVAL_SECONDS=60
DEFAULT_CITY_NAME=NeoTokyo
DEFAULT_CITY_MOOD=50
DEFAULT_DRAMA_LEVEL=20
DEFAULT_ROMANCE_LEVEL=30
DEFAULT_CONFLICT_LEVEL=15

# ============================================================================
# Web Panel Configuration
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================================================
# Logging & Monitoring
# ============================================================================
LOG_LEVEL=INFO
ENABLE_METRICS=true
METRICS_PORT=9090

# ============================================================================
# Oracle Cloud Configuration (for deployment)
# ============================================================================
# These are used by the deployment scripts
ORACLE_REGION=us-ashburn-1
ORACLE_COMPARTMENT_ID=your-compartment-id
ORACLE_SUBNET_ID=your-subnet-id
ORACLE_SECURITY_LIST_ID=your-security-list-id
ORACLE_AVAILABILITY_DOMAIN=your-availability-domain

# ============================================================================
# SSL/TLS Configuration
# ============================================================================
SSL_CERT_PATH=/etc/nginx/ssl/alexverse.crt
SSL_KEY_PATH=/etc/nginx/ssl/alexverse.key
DOMAIN=alexverse.yourdomain.com